{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "ssh-man",
  "outputfilename": "ssh-man",
  "frontend:install": "../scripts/pnpm.sh install --frozen-lockfile",
  "frontend:build": "../scripts/pnpm.sh run build",
  "frontend:dev:watcher": "../scripts/pnpm.sh run dev",
  "frontend:dir": "frontend",
  "author": {
    "name": "OpenCode"
  },
  "info": {
    "protocols": [
      {
        "scheme": "http",
        "description": "HTTP web links",
        "role": "Viewer"
      },
      {
        "scheme": "https",
        "description": "HTTPS web links",
        "role": "Viewer"
      }
    ]
  }
}
